# =============================================================================
# BOILERPLATE ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Node Environment
# -----------------------------------------------------------------------------
NODE_ENV=development
# Options: development | production | test

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
# Backoffice admin panel
NEXT_PUBLIC_BACKOFFICE_URL=http://localhost:3001

# Landing page (public site)
NEXT_PUBLIC_LANDING_URL=http://localhost:3002

# API URL for landing page to fetch public data
NEXT_PUBLIC_API_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/your_db_name

# Direct database URL for Prisma migrations (overrides pool settings)
# Uncomment if you need direct connection for migrations
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/your_db_name

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------
# Secret key for JWT tokens - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-this-to-a-random-secret-key

# URL where NextAuth is running (auto-detected in most cases)
NEXTAUTH_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# OAuth Providers (Optional)
# -----------------------------------------------------------------------------
# Google OAuth
# Get credentials from: https://console.cloud.google.com/
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
# Get credentials from: https://github.com/settings/developers
# GITHUB_ID=your-github-client-id
# GITHUB_SECRET=your-github-client-secret

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
# S3-compatible storage (AWS S3, MinIO, DigitalOcean Spaces, etc.)
# Leave empty to use local file system storage
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_FORCE_PATH_STYLE=false

# CDN URL for serving files (CloudFront, Cloudflare R2, etc.)
# Leave empty to serve files directly from storage
CDN_URL=https://cdn.example.com

# -----------------------------------------------------------------------------
# Email Configuration (Optional)
# -----------------------------------------------------------------------------
# SMTP settings for sending emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Cache Revalidation
# -----------------------------------------------------------------------------
# Secret key for cache revalidation webhook
# Generate with: openssl rand -base64 32
REVALIDATE_SECRET=change-this-to-another-random-secret

# Landing page URL for revalidation triggers
LANDING_URL=http://localhost:3002

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable features globally
NEXT_PUBLIC_FEATURE_DARK_MODE=true
NEXT_PUBLIC_FEATURE_ANALYTICS=false
NEXT_PUBLIC_FEATURE_BETA_FEATURES=false

# -----------------------------------------------------------------------------
# External Services (Optional)
# -----------------------------------------------------------------------------
# Analytics (Google Analytics, Plausible, etc.)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Error tracking (Sentry, etc.)
# NEXT_PUBLIC_SENTRY_DSN=https://...

# Monitoring (LogRocket, etc.)
# NEXT_PUBLIC_LOGROCKET_APP_ID=your-app-id

# -----------------------------------------------------------------------------
# Development Tools
# -----------------------------------------------------------------------------
# Enable debug mode for verbose logging
DEBUG=false

# -----------------------------------------------------------------------------
# Production Settings
# -----------------------------------------------------------------------------
# Set to true in production
NEXT_PUBLIC_IS_PRODUCTION=false
